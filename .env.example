# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Basin Forms API Configuration
# Get your Basin endpoint and basket IDs from https://usebasin.com
VITE_BASIN_ENDPOINT="https://basin.glitch.me"
VITE_BASIN_TICKET_ID="yhttps://usebasin.com/f/5712a2bac7a7"
VITE_BASIN_CONTACT_ID="your_contact_basket_id"

# Server Configuration
PORT=3001

# Supabase Configuration
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your_public_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key"
SUPABASE_BUCKET="ticket-uploads"
# Together API Integration 
# Together API key for calling Together inference / email endpoints
TOGETHER_API_KEY="tgp_v1_d-AaoCoSOfMRuZa_7XWyfUFUJhJZgUYzFJATBRrsqsw"

# Email routing
# Destination for all registration emails
EMAIL_TO="rubcosizweni.office@gmail.com"
# Optional: From address used when sending via SMTP fallback
EMAIL_FROM="noreply@example.com"
# If you prefer Together to send the email directly set to "true".
# If false, the function will fallback to SMTP using EMAIL_USER/EMAIL_PASSWORD
TOGETHER_SEND_EMAIL="true"

# SMTP (fallback) credentials — required only if TOGETHER_SEND_EMAIL is false
EMAIL_USER="rubcosizweni.office@gmail.com"
EMAIL_PASSWORD="zwak cjut tyuf avqb"